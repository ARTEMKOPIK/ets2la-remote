<?xml version="1.0" encoding="utf-8"?>
<!--
    Cleartext policy for ETS2LA Remote.

    The primary use case is talking HTTP / WS to the ETS2LA backend on the
    user's local network (RFC1918 / link-local / loopback / mDNS `.local`).
    Android's `<domain>` tag matches hostnames as literal strings and does
    NOT CIDR-match IPs — `<domain>192.168.0.0</domain>` matches only the
    literal host `192.168.0.0`, not `192.168.1.5`. Enumerating every
    `/24` in RFC1918 is infeasible, so historically we listed the `/16`
    base addresses which accidentally blocked every real LAN IP.

    The HTTPS endpoints the app talks to (GitHub release API, APK
    download URL) are always `https://…` in code, so Android's scheme
    enforcement still applies and this permissive default does not
    downgrade them to cleartext.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
</network-security-config>
