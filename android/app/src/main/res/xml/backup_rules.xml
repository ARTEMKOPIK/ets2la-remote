<?xml version="1.0" encoding="utf-8"?>
<!--
    Legacy (Android 11 and below) auto-backup rules. SharedPreferences
    hold saved hosts and MAC addresses; treat that as user data we do
    NOT want silently copied to Google Drive.
-->
<full-backup-content>
    <exclude domain="sharedpref" path="." />
    <exclude domain="file" path="." />
    <exclude domain="database" path="." />
</full-backup-content>
